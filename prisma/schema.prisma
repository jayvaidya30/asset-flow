// AssetFlow — shared data contract.
// This file is owned jointly; agree on changes in the team channel before editing.
// Track owners are noted per section so you know who to ping.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditResult {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

// ─────────────────────────────────────────────────────────────
// TRACK 1 — Platform & Org Setup (auth, employees, departments, categories)
// ─────────────────────────────────────────────────────────────

model Employee {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(EMPLOYEE)
  status       ActiveStatus @default(ACTIVE)

  departmentId String?
  department   Department?  @relation("DepartmentMembers", fields: [departmentId], references: [id])

  headedDepartments Department[] @relation("DepartmentHead")

  // Back-relations (owned by other tracks, listed here so Prisma is happy)
  allocationsHeld       Allocation[]         @relation("AllocationHolder")
  allocationsMade       Allocation[]         @relation("AllocatedBy")
  transfersRequested    Transfer[]           @relation("TransferRequestedBy")
  transfersFrom         Transfer[]           @relation("TransferFrom")
  transfersTo           Transfer[]           @relation("TransferTo")
  transfersApproved     Transfer[]           @relation("TransferApprovedBy")
  bookings              Booking[]            @relation("BookedBy")
  maintenanceRaised     MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceApproved   MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  maintenanceAssigned   MaintenanceRequest[] @relation("MaintenanceTechnician")
  auditCyclesCreated    AuditCycle[]         @relation("AuditCycleCreatedBy")
  auditAssignments      AuditAssignment[]
  auditItemsChecked     AuditItem[]          @relation("AuditItemAuditor")
  notifications         Notification[]
  activityLogs          ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, status])
  @@index([departmentId, status])
}

model Department {
  id       String       @id @default(cuid())
  name     String
  status   ActiveStatus @default(ACTIVE)

  headId String?
  head   Employee? @relation("DepartmentHead", fields: [headId], references: [id])

  parentId String?
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")

  members     Employee[]   @relation("DepartmentMembers")
  allocations Allocation[]
  bookings    Booking[]
  auditCycles AuditCycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([headId])
  @@index([parentId])
}

model AssetCategory {
  id     String       @id @default(cuid())
  name   String       @unique
  status ActiveStatus @default(ACTIVE)

  // Optional category-specific field definitions, e.g. [{ "key": "warrantyMonths", "label": "Warranty (months)", "type": "number" }]
  customFields Json?

  assets Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// TRACK 2 — Asset Lifecycle (registration, allocation, transfer)
// ─────────────────────────────────────────────────────────────

model Asset {
  id              String      @id @default(cuid())
  assetTag        String      @unique // auto-generated, e.g. AF-0001
  name            String
  serialNumber    String?
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id])
  acquisitionDate DateTime?
  acquisitionCost Decimal?    @db.Decimal(12, 2) // ranking/reports only, NOT accounting
  condition       String?
  location        String?
  photoUrl        String?
  documentsUrl    String?
  isBookable      Boolean     @default(false) // shared/bookable flag
  status          AssetStatus @default(AVAILABLE)

  // Category-specific values keyed to AssetCategory.customFields
  customValues Json?

  allocations         Allocation[]
  transfers           Transfer[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([categoryId])
}

model Allocation {
  id String @id @default(cuid())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  // Held by an employee OR a department (at least one set)
  holderId     String?
  holder       Employee?   @relation("AllocationHolder", fields: [holderId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  allocatedById String
  allocatedBy   Employee @relation("AllocatedBy", fields: [allocatedById], references: [id])

  allocatedAt        DateTime         @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  checkInCondition   String?
  checkInNotes       String?
  status             AllocationStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([expectedReturnDate])
  @@index([holderId, status])
  @@index([departmentId, status])
}

model Transfer {
  id String @id @default(cuid())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  fromEmployeeId String?
  fromEmployee   Employee? @relation("TransferFrom", fields: [fromEmployeeId], references: [id])
  toEmployeeId   String
  toEmployee     Employee  @relation("TransferTo", fields: [toEmployeeId], references: [id])

  requestedById String
  requestedBy   Employee @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    Employee? @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  status TransferStatus @default(REQUESTED)
  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([requestedById])
  @@index([toEmployeeId])
}

// ─────────────────────────────────────────────────────────────
// TRACK 3 — Booking, Maintenance & Audit
// ─────────────────────────────────────────────────────────────

model Booking {
  id String @id @default(cuid())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  bookedById String
  bookedBy   Employee @relation("BookedBy", fields: [bookedById], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  startTime DateTime
  endTime   DateTime
  purpose   String?
  status    BookingStatus @default(UPCOMING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId, startTime, endTime]) // overlap queries
  @@index([status])
  @@index([bookedById])
  @@index([departmentId])
}

model MaintenanceRequest {
  id String @id @default(cuid())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  raisedById String
  raisedBy   Employee @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])

  description String
  priority    MaintenancePriority @default(MEDIUM)
  photoUrl    String?
  status      MaintenanceStatus   @default(PENDING)

  approvedById String?
  approvedBy   Employee? @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])
  technicianId String?
  technician   Employee? @relation("MaintenanceTechnician", fields: [technicianId], references: [id])

  resolutionNotes String?
  resolvedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([raisedById, status])
}

model AuditCycle {
  id     String           @id @default(cuid())
  name   String
  status AuditCycleStatus @default(OPEN)

  scopeDepartmentId String?
  scopeDepartment   Department? @relation(fields: [scopeDepartmentId], references: [id])
  scopeLocation     String?

  startDate DateTime
  endDate   DateTime

  createdById String
  createdBy   Employee @relation("AuditCycleCreatedBy", fields: [createdById], references: [id])

  assignments AuditAssignment[]
  items       AuditItem[]

  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AuditAssignment {
  id       String @id @default(cuid())
  cycleId  String
  cycle    AuditCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  auditorId String
  auditor   Employee   @relation(fields: [auditorId], references: [id])

  @@unique([cycleId, auditorId])
}

model AuditItem {
  id      String @id @default(cuid())
  cycleId String
  cycle   AuditCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  assetId String
  asset   Asset      @relation(fields: [assetId], references: [id])

  result    AuditResult @default(PENDING)
  auditorId String?
  auditor   Employee?   @relation("AuditItemAuditor", fields: [auditorId], references: [id])
  notes     String?
  checkedAt DateTime?

  @@unique([cycleId, assetId])
  @@index([result])
}

// ─────────────────────────────────────────────────────────────
// TRACK 4 — Dashboard, Reports & Notifications (cross-cutting)
// Written by every track via helpers in src/lib/notifications.ts and src/lib/activity.ts
// ─────────────────────────────────────────────────────────────

model Notification {
  id     String  @id @default(cuid())
  userId String
  user   Employee @relation(fields: [userId], references: [id])

  type    String  // e.g. ASSET_ASSIGNED, MAINTENANCE_APPROVED, BOOKING_REMINDER, OVERDUE_RETURN
  title   String
  message String
  linkUrl String?
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

model ActivityLog {
  id      String @id @default(cuid())
  actorId String?
  actor   Employee? @relation(fields: [actorId], references: [id])

  action     String // e.g. ASSET_REGISTERED, TRANSFER_APPROVED, AUDIT_CLOSED
  entityType String // e.g. Asset, Booking, MaintenanceRequest
  entityId   String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
